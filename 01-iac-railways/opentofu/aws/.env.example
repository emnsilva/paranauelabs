# Arquivo de exemplo para armazenar credenciais estáticas. Não faça commit com as suas chaves!
# 1. Credenciais da AWS (Lidas direto, sem prefixo)
export AWS_ACCESS_KEY_ID="Chave do usuário IAM"
export AWS_SECRET_ACCESS_KEY="Chave secreta do usuário IAM"

# 2. Variáveis do seu código (EXIGEM o prefixo TF_VAR_)
export TF_VAR_AWS_REGION_PRIMARY="Região primária dos recursos"
export TF_VAR_AWS_REGION_SECONDARY="Região de backup dos recursos"
