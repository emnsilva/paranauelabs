# Configuração de environment para credenciais estáticas na AWS
# Altere as regiões para as regiões do seu projeto
values:
  regionA: "sa-east-1"
  regionB: "us-east-1"
  aws:
    login:
      fn::open::aws-login:
        static:
          accessKeyId: "Chave do usuario AWS"
          secretAccessKey: "Chave secreta do usuario AWS"
  environmentVariables:
    AWS_ACCESS_KEY_ID: ${aws.login.accessKeyId}
    AWS_SECRET_ACCESS_KEY: ${aws.login.secretAccessKey}
  pulumiConfig:
    # Usamos o nome do seu projeto para expor as duas variáveis de forma abrangente
    seu_projeto:regionPrimary: ${regionA}
    seu_projeto:regionSecondary: ${regionB}
