# Selecione apenas um bloco por vez e deixe os outros comentados (#)

# --- Opção 1: Ollama (Local - Llama 3.2) ---
# Lembre-se de rodar: ollama pull llama3.2:3b
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=
MODEL_NAME=llama3.2:3b

# --- Opção 2: QWEN - Alibaba (Local via Ollama) ---
# Lembre-se de rodar: ollama pull qwen2.5:3b
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=
# MODEL_NAME=qwen2.5:3b

# --- Opção 3: DeepSeek (Local via Ollama) ---
# Lembre-se de rodar: ollama pull deepseek-r1:7b (Requer mais RAM)
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=
# MODEL_NAME=deepseek-r1:7b

# --- Opção 4: OpenAI (Nuvem - Pago) ---
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-sua-chave-real-aqui
# MODEL_NAME=gpt-4o-mini

# Namespace(s) que o agente monitora. Use 'all' para todos os namespaces.
MONITOR_NAMESPACES=all

# Modo de operação do agente:
#   dry-run    = Só diagnostica e notifica. Não executa nenhuma ação no cluster.
#   approval   = Diagnostica, propõe ação e aguarda aprovação humana (Human-in-the-Loop).
#   auto       = Executa ações de baixo risco automaticamente (whitelist).
OPERATION_MODE=dry-run




# --- Notificações ---
# Escolha uma plataforma: slack | teams | whatsapp
# Deixe as outras seções comentadas
# NOTIFICATION_PROVIDER=slack

# --- Slack ---
# SLACK_BOT_TOKEN=xoxb-SEU-TOKEN-AQUI
# SLACK_CHANNEL=#alertas-k8s

# --- Teams (descomente se for usar) ---
# TEAMS_WEBHOOK_URL=https://sua-empresa.webhook.office.com/webhookb2/SEU-URL-AQUI

# --- WhatsApp (descomente se for usar) ---
# Compatível com Evolution API, Z-API, etc.
# WHATSAPP_WEBHOOK_URL=http://localhost:8080/message/send-text
# WHATSAPP_INSTANCE=SEU-ID-DA-INSTANCIA
# WHATSAPP_NUMBER=551234567890